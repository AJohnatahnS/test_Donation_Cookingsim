<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- The machine-wide NuGet.Config points at a fallback folder that no longer
       exists (D:\program\VS\SS\NuGetPackages), which crashes ResolvePackageAssets.
       This project references only local DLLs (game + BepInEx), so clear all
       package sources and fallback folders to build fully offline. -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
  <packageSources>
    <clear />
  </packageSources>
</configuration>
