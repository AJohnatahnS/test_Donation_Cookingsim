<?xml version="1.0" encoding="utf-8"?>
<!-- This machine's global NuGet.Config points packageSources/fallbackPackageFolders
     at D:\program\VS\SS\NuGetPackages, which does not exist and crashes restore.
     We reference every assembly from local DLLs (no packages), so clear both. -->
<configuration>
  <packageSources>
    <clear />
  </packageSources>
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
